# Supabase — vital-organs-entertainment project
# Dashboard: https://supabase.com/dashboard/project/tezzihhkqlovynybaypu

# IMPORTANT: Use your Supabase API URL, NOT your website domain.
# Correct format: https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://tezzihhkqlovynybaypu.supabase.co

# Use the anon (legacy) or publishable key from:
# Supabase Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Server-only — Project Settings → API Keys → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Public app URL used for Stripe success/cancel redirects
# Local dev: http://localhost:3000
# Vercel production: https://vitalorgansent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HLS live stream URL (.m3u8) — replace with Ian's production feed on event night
NEXT_PUBLIC_HLS_STREAM_URL=https://your-cdn.example.com/awakening-live.m3u8

# Stripe webhook signing secret — from Dashboard or `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here
