# Supabase — vital-organs-entertainment project
# Dashboard: https://supabase.com/dashboard/project/tezzihhkqlovynybaypu

# IMPORTANT: Use your Supabase API URL, NOT https://supabase.co
# Correct format: https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://tezzihhkqlovynybaypu.supabase.co

# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs must include:
# - http://localhost:3000/auth/callback
# - http://localhost:3000/auth/callback?next=/dashboard/live
# - https://your-production-domain.com/auth/callback
# - https://your-production-domain.com/auth/callback?next=/dashboard/live

# Use the anon (legacy) or publishable key from:
# Supabase Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Server-only — Project Settings → API Keys → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Public app URL used for Stripe success/cancel redirects
# Local dev: http://localhost:3000
# Vercel production: https://vitalorgansent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HLS live stream URL (.m3u8) — replace with Ian's production feed on event night
NEXT_PUBLIC_HLS_STREAM_URL=https://your-cdn.example.com/awakening-live.m3u8

# Stripe webhook signing secret — from Dashboard or `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here

# Admin stream toggle — POST /api/stream/toggle (X-Admin-Secret-Key header)
ADMIN_SECRET_KEY=your-long-secure-admin-passphrase-here
ADMIN_EMAILS=info@vitalorgansent.com

# Operations dashboard — comma-separated admin emails allowed at /ops and /ops/live-hub
# Without this (and without user_metadata.is_ops_admin), /ops returns application 404.
ADMIN_EMAILS=you@example.com,ops@example.com

# Ops auth diagnostics — logs safe gate decisions to server console when true
OPS_AUTH_DEBUG=false

# Optional attendee live render diagnostics — browser console.debug when true
NEXT_PUBLIC_LIVE_RENDER_DEBUG=false

# Build-phase only — skip paid ticket checks for authenticated users (server-only, never in production)
LIVE_ACCESS_DEV_BYPASS=false

# Live Hub vMix adapter — local vMix HTTP API on the operator desktop (optional; mock when unset)
# Note: Vercel-hosted routes cannot reach operator-local 127.0.0.1 — use desktop Live Hub boundary.
VMIX_API_BASE_URL=http://127.0.0.1:8088/api

# Live Hub Restream adapter — server-only token (optional; mock used when unset)
RESTREAM_API_TOKEN=
